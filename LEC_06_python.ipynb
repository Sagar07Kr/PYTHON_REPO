import pandas as pd

df=pd.read_csv("student_data.csv")
# This adds the new column to the data
df['age']= 20;

# column rename , this returns new dataframe
df = df.rename(columns ={'assignments_completed':'assign_completed'})
df
# This replace the coulmn with previous column in data
df = df.rename(columns ={'assignments_completed':'assign_completed'},inplace=True)
df
# Remove rows and columns
df.drop('assign_completed', axis=1)
display(df)

