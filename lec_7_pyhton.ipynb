import pandas as pd
df=pd.read_csv('student_data.csv')

#--------------------------------------------------------------------------------

# this is used to group the data according to aggregate function i.e.(sum,count,max,min)
# Syntax: (jis column ke group bnane hai)[jis column ke basis pr group bnane hai ].agg(jo aggregate..
# ..function use karna hai)
df.groupby('placement_status')['placement_status'].agg('count')

df.groupby('placement_status')['exam_score'].agg('mean')

#--------------------------------------------------------------------------------

ef grades(x):
  if x>=90:
    return 'A'
  elif(x<90 and x>=50):
    return 'B'
  else:
    return 'F'


df['grade']=df['exam_score'].apply(grades)
df

