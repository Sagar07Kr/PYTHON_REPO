import pandas as pd

df1=pd.DataFrame({
    'id':[1,2,3,4],
    'name':['Raja','Rani','Rahul','Rhea'],
    'age':[25,30,35,40]
})

df2=pd.DataFrame({
    'id':[3,4,5,6],
    'name':['Rahul','Rhea','Ravi','Reema'],
    'age':[35,40,45,50]
})
# inner joint gives the common data of both tables
df3=pd.merge(df1,df2, on='id' , how='inner')
df3.rename(columns={'name_x':'name1','name_y':'name2'},inplace=True)
display(df3)

# ---------------------------------------------------------------------------------

df3=pd.merge(df1,df2, on='id' , how='left')
display(df3)

# left joint gives the whole data of left table and put NaN if table 2 data is not present

# ---------------------------------------------------------------------------------

df3=pd.merge(df1,df2, on='id' , how='right')
display(df3)
# right joint gives the whole data of right table and put NaN if table 1 data is not present


# ---------------------------------------------------------------------------------

df3=pd.merge(df1,df2, on='id' , how='outer')
display(df3)

# outer joint gives all values of both table and put NaN if any value does not exist

# ---------------------------------------------------------------------------------

df3=pd.merge(df1,df2, how='cross')
display(df3)

# A cross join in pandas creates a Cartesian product of two DataFrames, meaning it combines
# every row from the first DataFrame with every row from the second DataFrame

