# Question 2
import numpy as np
a=np.random.randint(1,90,25)
# or stock=np.random.randint(1,90,(5,5))
b=np.random.randint(1,90,25)
stock=a.reshape((5,5))
demand=b.reshape((5,5))
print("stocks:")
print(stock)
print("\n")
print("Demand:")
print(demand)
print("\n")

print("remaining stocks:")
rem_stock=stock-demand
print(rem_stock)
print("\n")

print("replacing negative stocks with 0..........")
s=np.where(rem_stock<0,0,rem_stock)
print(s)
print("\n")

print("shortage:")
shortage=np.sum(np.where(rem_stock<0,-1*rem_stock,0),axis=0)
print(shortage)
print("\n")

print("No shortage product:")
no_shortage=np.sum(np.where(rem_stock>=0,1,0))
print(no_shortage)
print("\n")

print("sorted remaining product:")
sorted_rem_product=np.sort(rem_stock,axis=1)
print(sorted_rem_product)

