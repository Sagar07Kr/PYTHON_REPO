import numpy as np

# selecting elements of matrix
a=np.random.randint(1,90,25);

# Giving dim to matrix
b=a.reshape((5,5))
print (b)

# row wise mean of matrix
print(f"mean of all rows {b.mean(axis=1)}")

# column wise mean of matrix
print(f"mean of all columns {b.mean(axis=0)}")

# replacing all even numbers with -1
print(" replacing even number with -1 ............")
b=np.where(b%2==0,-1,b)

# row wise sorting matrix
print("row wise sorting matrix .............")
print(np.sort(b,axis=0))

# column wise sorting matrix
print("column wise sorting matrix ...............")
print(np.sort(b,axis=1))

# row wise sum of matrix
print("row wise sum of matrix ..................")
print(b.sum(axis=1))

# column wise sum of matrix
print("column wise sum of matrix ................")
print(b.sum(axis=0))

# counting -1 column wise
print("counting -1 column wise ................")
cnt=np.sum(b== -1,axis=0)
print(cnt)
# method 2
print("method 2........")
cnt1=np.sum(np.where(b<0,1,0),axis=0)
print(cnt1)


